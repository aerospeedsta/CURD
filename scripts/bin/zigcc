#!/bin/bash
TARGET=""
ARGS=()
PREV_WAS_TARGET=0

for arg in "$@"; do
    if [[ "$arg" == --target=* ]]; then
        VAL="${arg#--target=}"
        CLEAN_VAL=$(echo "$VAL" | sed 's/-unknown-/-/')
        TARGET="$CLEAN_VAL"
        ARGS+=("-target" "$CLEAN_VAL")
    elif [ "$PREV_WAS_TARGET" = "1" ]; then
        CLEAN_VAL=$(echo "$arg" | sed 's/-unknown-/-/')
        TARGET="$CLEAN_VAL"
        ARGS+=("$CLEAN_VAL")
        PREV_WAS_TARGET=0
    elif [ "$arg" = "-target" ]; then
        ARGS+=("-target")
        PREV_WAS_TARGET=1
    else
        ARGS+=("$arg")
    fi
done

exec zig cc "${ARGS[@]}"